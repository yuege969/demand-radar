# Reddit API (注册 OAuth App: https://www.reddit.com/prefs/apps, 选择 "script" 类型)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=demand-radar/1.0

# LLM API (OpenAI-compatible: DeepSeek/Qwen/Moonshot/Zhipu/OpenAI etc.)
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Server
ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=sqlite:///./demand_radar.db
MAX_POSTS_PER_BATCH=50
ADMIN_API_TOKEN=

# Daily report generation time (24h format)
REPORT_GENERATION_HOUR=8
